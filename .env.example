NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/repo_crawler
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT_MS=30000
GITHUB_TOKEN=your-github-pat-here
GITHUB_API_URL=https://api.github.com/graphql
CRAWLER_TARGET=100000
CRAWLER_QUERY_PAGE_SIZE=100
CRAWLER_DB_BATCH_SIZE=5000
CRAWLER_SHARD_CONCURRENCY=20
CRAWLER_MAX_RUNTIME_SECONDS=600
CRAWLER_MIN_RATE_LIMIT_REMAINING=25
CRAWLER_RETRY_MAX_ATTEMPTS=6
CRAWLER_RETRY_BASE_DELAY_MS=250
CRAWLER_ENFORCE_TARGET=false
RUN_SUMMARY_PATH=artifacts/run-summary.json
EXPORT_PATH=artifacts/repositories.json
UI_DATASET_PATH=artifacts/ui-dataset.json
UI_TOP_REPOSITORIES_LIMIT=500
